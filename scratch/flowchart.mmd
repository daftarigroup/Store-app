graph TD
    %% 1. Initiation
    Start([Start]) --> CreateIndent[1. Create Indent]
    
    %% 2. Approval
    CreateIndent --> ApprIndent{2. Indent Approved?}
    ApprIndent -->|No| RejectIndent[Reject / Revise]
    ApprIndent -->|Yes| Procurement[3. Pending Indent Dashboard]
    
    %% 3. Procurement
    Procurement --> CheckType{3-Party Quote Required?}
    CheckType -->|Yes| ThreeQuotes[Gather 3 Quotes] --> TechAppr[Technical Approval] --> RateAppr[Rate Approval]
    CheckType -->|No| DirectQuote[Direct Vendor Selection] --> RateAppr
    
    %% 4. PO
    RateAppr --> CreatePO[4. Create Purchase Order]
    
    %% 5. Logistics
    CreatePO --> Lifting[5. Material Lifting]
    Lifting --> BillCheck{Bill Attached?}
    BillCheck -->|No| BillMissing[Bill Missing Dashboard]
    BillMissing -.-> |Upload Bill| StoreIn
    BillCheck -->|Yes| StoreIn[6. Store In / Physical Receipt]
    
    %% 6. Receiving
    StoreIn --> HODAppr{7. HOD Approval?}
    HODAppr -->|Reject| DebitNote[Return / Debit Note]
    HODAppr -->|Approve| Inventory[(8. Inventory Ledger)]
    
    %% 7. Post-Receiving Flow
    Inventory --> Issue[Store Issue]
    Inventory --> Transfer[Stock Transfer]
    
    HODAppr -->|Triggers| Accounts[9. Finance / Payment]
    Accounts --> PayCheck{Payment Approved?}
    PayCheck -->|Yes| MakePayment[Make Payment]
    
    %% 8. Audit
    MakePayment --> AuditFlow[10. Audit -> Reaudit -> Tally]
    AuditFlow --> Finish([End Process])

    %% Styling
    style Inventory fill:#3498db,stroke:#2980b9,color:#fff,stroke-width:4px
    style ApprIndent fill:#f1c40f,stroke:#f39c12,color:#fff
    style CheckType fill:#f1c40f,stroke:#f39c12,color:#fff
    style BillCheck fill:#f1c40f,stroke:#f39c12,color:#fff
    style HODAppr fill:#f1c40f,stroke:#f39c12,color:#fff
    style PayCheck fill:#f1c40f,stroke:#f39c12,color:#fff
